SELECT category,
       SUM(price * quantity) AS total_sum,
       AVG(price * quantity) AS category_avg,
       SUM(SUM(price * quantity)) OVER () AS overall_total,
       AVG(SUM(price * quantity)) OVER () AS overall_avg
FROM orders_data
GROUP BY category
ORDER BY total_sum DESC;




select category , sum(price*quantity) as total_revenue , avg(total_revenue) as total_avg, sum(sum(total_revenue)) over () as overal_sum
from orders_data 
group by category  order by overal_sum;



SELECT category, 
       SUM(price * quantity) AS total_revenue, 
       AVG(price * quantity) AS category_avg,
       AVG(SUM(price * quantity)) OVER () AS total_avg,
       SUM(SUM(price * quantity)) OVER () AS overall_sum
