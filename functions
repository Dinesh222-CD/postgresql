select * from orders_data ;

---- 1. Second Highest Revenue Category

select category , sum(price*quantity) as total_revenue 
from orders_data 
group by category
order by total_revenue desc limit 1 offset 1;

---- . print Revenue of Electronics in category or “Find the total price of all orders belonging to the 'Electronics' category.”
---with group by 
select category , sum(price) as total_price_of_electronics
from orders_data 
where category ='Electronics'
group by category;
 
---without group by 
select sum(price)  as total_E 
from orders_data 
where category ='Electronics';

SELECT SUM(price)
FROM orders_data;

select category , sum(price) as total 
from orders_data
group by category 
order by total desc
limit 5 offset 0;


SELECT category,
       SUM(price) AS category_total,
       SUM(SUM(price)) OVER () AS overall_total
FROM orders_data
GROUP BY category
ORDER BY category_total DESC
LIMIT 5 OFFSET 0;

